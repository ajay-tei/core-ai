# Diva AI — Environment Variables
# Copy to .env and fill in real values. Never commit .env to source control.

# ── LLM Provider ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here          # Optional — for LiteLLM multi-provider

# ── LiteLLM Proxy (optional — set UseLiteLLM=true to enable) ─────────────────
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_BASE_URL=http://localhost:4000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no config needed, uses diva.db in app dir)
# DATABASE_PROVIDER=SQLite

# SQL Server (enterprise)
# DATABASE_PROVIDER=SqlServer
# DB_CONNECTION_STRING=Server=localhost;Database=Diva;Trusted_Connection=True;MultipleActiveResultSets=true;
# SQL_SA_PASSWORD=StrongP@ssword1          # For docker-compose SQL Server container
# USE_RLS=false                            # Set true to enable SQL Server RLS

# ── OAuth / JWT ───────────────────────────────────────────────────────────────
OAUTH_AUTHORITY=https://your-auth-provider.com
OAUTH_AUDIENCE=diva-api
OAUTH_JWKS_URI=https://your-auth-provider.com/.well-known/jwks.json

# ── Observability ─────────────────────────────────────────────────────────────
SEQ_SERVER_URL=http://localhost:5341
OTEL_ENDPOINT=http://localhost:4317

# ── Temporal (scheduled workflows) ───────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ── Kafka (event-driven triggers) ────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=diva-agent-consumer

# ── Admin Portal ──────────────────────────────────────────────────────────────
ADMIN_PORTAL_CORS_ORIGIN=http://localhost:3000
PORTAL_ORIGIN=http://localhost:5173           # Docker: override with your portal's public URL

# ── Credentials Vault ─────────────────────────────────────────────────────────
# AES-256-GCM master key for encrypting MCP credential secrets.
# MUST be a stable base64-encoded 32-byte key. If left empty, an ephemeral key is
# generated per startup — all stored credentials will be lost on container restart.
# Generate: openssl rand -base64 32
CREDENTIALS_MASTER_KEY=your-base64-32-byte-key-here

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:8080

# ── Admin Portal (Vite) ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080

# ── White-Labeling / Branding ────────────────────────────────────────────────
# Change the product name without forking. Values below are defaults.
# Changing Slug or LocalIssuer/ApiAudience after go-live invalidates sessions/JWTs.
AppBranding__ProductName=TEI AI
AppBranding__Slug=tei
AppBranding__ApiAudience=tei-api
AppBranding__LocalIssuer=tei-local

# ── SMTP Email (job notifications) ────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email sending (silent no-op, no errors thrown).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key-here
SMTP_FROM_ADDRESS=noreply@yourcompany.com
SMTP_FROM_NAME=TEI AI
