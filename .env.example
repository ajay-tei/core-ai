# Diva AI — Environment Variables
# Copy to .env and fill in real values. Never commit .env to source control.

# ── LLM Provider ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here          # Optional — for LiteLLM multi-provider

# ── LiteLLM Proxy (optional — set UseLiteLLM=true to enable) ─────────────────
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_BASE_URL=http://localhost:4000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is the default. This deployment targets an EXTERNAL SQL Server hosted on a
# separate Windows machine, so the bundled sqlserver container is NOT used and
# SQL_SA_PASSWORD is NOT needed. Start with the SQL Server overlay (NOT the enterprise
# overlay, which bundles its own SQL Server container):
#
#   docker compose -f docker-compose.tei.yml -f docker-compose.sqlserver.yml up -d
#
# Requirements on the Windows SQL Server:
#   • SQL (mixed-mode) authentication enabled — create the SQL login used below.
#   • TCP/IP protocol enabled (SQL Server Configuration Manager) and port 1433 open in
#     Windows Firewall. For a named instance on a dynamic port, run SQL Browser (UDP 1434).
#   • The login needs rights to create/own the Diva + DivaTrace databases (dbcreator, or
#     pre-create both and grant db_owner). EF Migrate/EnsureCreated create the schema.
# Use the machine's LAN IP/hostname below — NOT localhost (the container resolves that
# to itself). Format: Host,Port  (e.g. 192.168.1.50,1433 or SQLBOX\INSTANCE).
SQL_SERVER_HOST=192.168.1.50,1433
SQL_DB_NAME=Diva
SQL_TRACE_DB_NAME=DivaTrace
SQL_USER=diva_app
SQL_PASSWORD=your-sql-login-password

# Bare `dotnet run` (no Docker) reads these directly instead of the overlay:
#   Database__Provider=SqlServer
#   Database__SqlServer__ConnectionString=Server=192.168.1.50,1433;Database=Diva;User Id=diva_app;Password=...;TrustServerCertificate=true
#   ConnectionStrings__SessionTrace=Server=192.168.1.50,1433;Database=DivaTrace;User Id=diva_app;Password=...;TrustServerCertificate=true

# ── Data migration (one-time SQLite → SQL Server copy) ────────────────────────
# Source SQLite DB the DbMigrate tool reads from (copies all business data once).
# Run the one-shot migration against the external server (provisions schema, then copies):
#   docker compose -f docker-compose.tei.yml -f docker-compose.sqlserver.yml \
#     --profile migrate run --rm dbmigrate

# ── OAuth / JWT ───────────────────────────────────────────────────────────────
OAUTH_AUTHORITY=https://your-auth-provider.com
OAUTH_AUDIENCE=diva-api
OAUTH_JWKS_URI=https://your-auth-provider.com/.well-known/jwks.json

# ── Observability ─────────────────────────────────────────────────────────────
SEQ_SERVER_URL=http://localhost:5341
OTEL_ENDPOINT=http://localhost:4317

# ── Temporal (scheduled workflows) ───────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ── Kafka (event-driven triggers) ────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=diva-agent-consumer

# ── Admin Portal ──────────────────────────────────────────────────────────────
ADMIN_PORTAL_CORS_ORIGIN=http://localhost:3000
PORTAL_ORIGIN=http://localhost:5173           # Docker: override with your portal's public URL

# ── Credentials Vault ─────────────────────────────────────────────────────────
# AES-256-GCM master key for encrypting MCP credential secrets.
# MUST be a stable base64-encoded 32-byte key. If left empty, an ephemeral key is
# generated per startup — all stored credentials will be lost on container restart.
# Generate: openssl rand -base64 32
CREDENTIALS_MASTER_KEY=your-base64-32-byte-key-here

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:8080

# ── Admin Portal (Vite) ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080

# ── White-Labeling / Branding ────────────────────────────────────────────────
# Change the product name without forking. Values below are defaults.
# Changing Slug or LocalIssuer/ApiAudience after go-live invalidates sessions/JWTs.
AppBranding__ProductName=TEI AI
AppBranding__Slug=tei
AppBranding__ApiAudience=tei-api
AppBranding__LocalIssuer=tei-local

# ── SMTP Email (job notifications) ────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email sending (silent no-op, no errors thrown).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key-here
SMTP_FROM_ADDRESS=noreply@yourcompany.com
SMTP_FROM_NAME=TEI AI
