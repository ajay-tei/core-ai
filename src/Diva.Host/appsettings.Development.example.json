{
  "Database": {
    "Provider": "SQLite",
    "SQLite": {
      "ConnectionString": "Data Source=diva-dev.db"
    }
  },
  "LLM": {
    "HttpTimeoutSeconds": 600,
    "DirectProvider": {
      "Provider": "Anthropic",
      "ApiKey": "YOUR_ANTHROPIC_API_KEY_HERE",
      "Model": "claude-sonnet-4-6",
      "Endpoint": ""
    },
    "AvailableModels": [
      "claude-sonnet-4-6",
      "claude-opus-4-5-20251101",
      "claude-sonnet-4.6",
      "gpt-5.4-mini",
      "gpt-5-mini",
      "gpt-4.1",
      "gpt-4o"
    ]
  },
  "Agent": {
    "MaxIterations": 10,
    "MaxContinuations": 2,
    "DefaultTemperature": 0.7,
    "MaxToolResultChars": 8000,
    "MaxOutputTokens": 8192,
    "InjectToolStrategy": true,
    "Retry": {
      "MaxRetries": 3,
      "BaseDelayMs": 1000
    },
    "ContextWindow": {
      "BudgetTokens": 120000,
      "CompactionThreshold": 0.65,
      "KeepLastRawMessages": 6,
      "MaxHistoryTurns": 20
    }
  },
  "Verification": {
    "Mode": "Auto",
    "IncludeReasoningInResponse": true,
    "VerifierMaxTokens": 1024
  },
  "AdminPortal": {
    "CorsOrigin": "http://localhost:5173"
  },
  "TaskScheduler": {
    "IsEnabled": true,
    "PollIntervalSeconds": 10,
    "MaxConcurrentRuns": 3,
    "MaxQueuedRunsPerTask": 5,
    "MaxResponseStorageChars": 4000,
    "StuckRunTimeoutMinutes": 10
  },
  "OAuth": {
    "Enabled": true,
    "Authority": "https://dev-idp.example.com",
    "Audience": "diva-api",
    "ValidateIssuer": false,
    "ValidateAudience": false,
    "PropagateToken": true,
    "DefaultTenantId": 1,
    "ClaimMappings": {
      "TenantId": "tenant_id",
      "TenantName": "tenant_name",
      "UserId": "sub",
      "SiteIds": "site_ids",
      "Roles": "roles",
      "Groups": "groups",
      "AgentAccess": "agent_access",
      "TeamApiKey": "litellm_team_key"
    }
  },
  "LocalAuth": {
    "SigningKey": "CHANGE_ME_MIN_32_CHARS_dev-signing-key",
    "TokenExpiryHours": 8
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Diva.Sso.SsoAwareHttpMessageHandler": "Debug",
        "Diva.Infrastructure.Auth.TenantClaimsExtractor": "Debug",
        "Diva.Infrastructure.LiteLLM.McpConnectionManager": "Debug",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}